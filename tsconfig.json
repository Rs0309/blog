{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "aws-lambda"],
    "outDir": "dist"
  },
  "include": ["infra/**/*.ts", "src/**/*.ts", "tests/**/*.ts", "vitest.config.ts"]
}
